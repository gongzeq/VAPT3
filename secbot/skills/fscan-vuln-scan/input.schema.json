{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["target"],
  "properties": {
    "target": {
      "type": "string",
      "minLength": 3,
      "maxLength": 253,
      "pattern": "^(?:\\d{1,3}\\.){3}\\d{1,3}(?:/\\d{1,2})?$|^[a-z0-9][a-z0-9.\\-]*\\.[a-z]{2,}$"
    },
    "ports": {
      "type": "string",
      "maxLength": 128,
      "pattern": "^[\\d,\\-]+$",
      "default": "80,443,8080,8443"
    }
  }
}
