{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary"],
  "properties": {
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "report_path": {"type": ["string", "null"]},
        "asset_count": {"type": "integer", "minimum": 0},
        "finding_count": {"type": "integer", "minimum": 0},
        "status": {"type": "string"}
      }
    }
  }
}
