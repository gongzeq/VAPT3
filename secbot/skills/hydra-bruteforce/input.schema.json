{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["target", "service", "users", "passwords"],
  "properties": {
    "target": {"type": "string", "minLength": 1, "maxLength": 128},
    "service": {
      "type": "string",
      "enum": [
        "ssh", "ftp", "telnet", "rdp", "mysql", "postgres", "mssql",
        "smb", "redis", "http-get", "http-post-form"
      ]
    },
    "port": {"type": "integer", "minimum": 1, "maximum": 65535},
    "users": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 64},
      "minItems": 1,
      "maxItems": 64
    },
    "passwords": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 64},
      "minItems": 1,
      "maxItems": 500
    },
    "tasks": {"type": "integer", "minimum": 1, "maximum": 16, "default": 4},
    "form": {"type": "string", "maxLength": 256}
  }
}
