{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["targets"],
  "properties": {
    "targets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 253,
        "pattern": "^https?://[a-zA-Z0-9._\\-:/]+$|^(?:\\d{1,3}\\.){3}\\d{1,3}(?::\\d{1,5})?$|^[a-z0-9][a-z0-9.\\-]*\\.[a-z]{2,}(?::\\d{1,5})?$"
      }
    },
    "severity": {
      "type": "string",
      "enum": ["medium,high,critical", "high,critical", "critical"],
      "default": "medium,high,critical"
    },
    "tags": {
      "type": "string",
      "maxLength": 256,
      "pattern": "^[a-zA-Z0-9,_\\-]*$",
      "default": "cve,exposure,misconfig"
    },
    "templates": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256,
        "pattern": "^[a-zA-Z0-9_][a-zA-Z0-9_./\\-]*$"
      },
      "description": "Optional list of POC template paths under secbot/resource/poc/. Each item is a relative file (e.g. 'cve/2023/CVE-2023-1234.yaml') or subdirectory (e.g. 'cve/2023'). The LLM MUST glob secbot/resource/poc/**/*.yaml first and pass only the entries that match the target profile — do NOT enumerate the entire directory."
    }
  }
}
