{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "hits": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "required": ["url", "status", "length"],
        "properties": {
          "url": {"type": "string"},
          "input": {"type": "string"},
          "status": {"type": "integer"},
          "length": {"type": "integer"},
          "words": {"type": "integer"}
        }
      }
    },
    "elapsed_sec": {"type": "number"},
    "error": {"type": "string"},
    "cancelled": {"type": "boolean"}
  }
}
